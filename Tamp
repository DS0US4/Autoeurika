            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            font-size: 14px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.4);
            display: flex;
            flex-direction: column;
            gap: 8px;
            min-width: 180px;
            border: 1px solid #334155;
            opacity: 1;
        `;

        const title = document.createElement('div');
        title.textContent = '🤖 EURIKA Auto';
        title.style.cssText = 'font-weight: bold; font-size: 16px; color: #60a5fa; text-align: center;';
        overlay.appendChild(title);

        const statusRow = document.createElement('div');
        statusRow.style.cssText = 'display: flex; align-items: center; gap: 10px; width: 100%;';

        const spinner = document.createElement('div');
        spinner.id = 'eurika-spinner';
        spinner.style.cssText = `
            width: 20px;
            height: 20px;
            border: 3px solid #475569;
            border-top: 3px solid #60a5fa;
            border-radius: 50%;
            display: none;
            animation: eurika-spin 0.8s linear infinite;
        `;

        const statusText = document.createElement('span');
        statusText.id = 'eurika-status';
        statusText.textContent = isSurveyPage() ? '⏸️ Paused' : '⛔ Not a survey';

        statusRow.appendChild(spinner);
        statusRow.appendChild(statusText);
        overlay.appendChild(statusRow);

        const controlRow = document.createElement('div');
        controlRow.style.cssText = 'display: flex; gap: 8px; width: 100%;';

        const toggleBtn = document.createElement('button');
        toggleBtn.id = 'eurika-toggle';
        toggleBtn.textContent = isSurveyPage() ? '▶️ Start' : '⛔ Disabled';
        toggleBtn.style.cssText = `
            background: ${isSurveyPage() ? '#3b82f6' : '#475569'};
            color: white;
            border: none;
            padding: 6px 16px;
            border-radius: 6px;
            font-weight: bold;
            cursor: ${isSurveyPage() ? 'pointer' : 'not-allowed'};
            font-size: 13px;
            flex: 1;
            transition: background 0.2s;
        `;
        if (isSurveyPage()) {
            toggleBtn.addEventListener('mouseenter', () => {
                toggleBtn.style.background = toggleBtn.textContent.includes('Start') ? '#2563eb' : '#dc2626';
            });
            toggleBtn.addEventListener('mouseleave', () => {
                toggleBtn.style.background = toggleBtn.textContent.includes('Start') ? '#3b82f6' : '#ef4444';
            });
        }

        const resetBtn = document.createElement('button');
        resetBtn.textContent = '🔄 Reset';
        resetBtn.style.cssText = `
            background: #475569;
            color: white;
            border: none;
            padding: 6px 12px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 13px;
            flex: 0.5;
            transition: background 0.2s;
        `;
        resetBtn.addEventListener('mouseenter', () => { resetBtn.style.background = '#64748b'; });
        resetBtn.addEventListener('mouseleave', () => { resetBtn.style.background = '#475569'; });

        controlRow.appendChild(toggleBtn);
        controlRow.appendChild(resetBtn);
        overlay.appendChild(controlRow);

        const counter = document.createElement('div');
        counter.id = 'eurika-counter';
        counter.style.cssText = 'font-size: 12px; color: #94a3b8; align-self: flex-start;';
        counter.textContent = 'Questions: 0';
        overlay.appendChild(counter);

        document.body.appendChild(overlay);

        if (!document.getElementById('eurika-spin-style')) {
            const style = document.createElement('style');
            style.id = 'eurika-spin-style';
            style.textContent = `
                @keyframes eurika-spin {
                    0% { transform: rotate(0deg); }
                    100% { transform: rotate(360deg); }
                }
            `;
            document.head.appendChild(style);
        }

        // ---- EVENT HANDLERS ----
        toggleBtn.addEventListener('click', function() {
            if (!isSurveyPage()) {
                showToast('⛔ No survey detected on this page.', '#ef4444');
                return;
            }
            if (isRunning) {
                stopRequested = true;
                toggleBtn.textContent = '⏳ Stopping...';
                toggleBtn.style.background = '#f59e0b';
            } else {
                stopRequested = false;
                isRunning = true;
                toggleBtn.textContent = '⏹️ Stop';
                toggleBtn.style.background = '#ef4444';
                spinner.style.display = 'block';
                statusText.textContent = '▶️ Running...';
                if (window._eurikaRunner && typeof window._eurikaRunner === 'function') {
                    window._eurikaRunner();
                } else {
                    runAutoFiller();
                }
            }
        });

        resetBtn.addEventListener('click', function() {
            if (isRunning) {
                stopRequested = true;
                setTimeout(() => resetUI(), 500);
            } else {
                resetUI();
            }
        });

        function resetUI() {
            isRunning = false;
            stopRequested = false;
            currentQuestionCount = 0;
            toggleBtn.textContent = isSurveyPage() ? '▶️ Start' : '⛔ Disabled';
            toggleBtn.style.background = isSurveyPage() ? '#3b82f6' : '#475569';
            spinner.style.display = 'none';
            statusText.textContent = isSurveyPage() ? '⏸️ Paused' : '⛔ Not a survey';
            counter.textContent = 'Questions: 0';
            delete window._eurikaRunner;
        }

