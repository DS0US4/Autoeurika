// ==UserScript==
// @name         EURIKA Surveys Automated
// @namespace    http://tampermonkey.net/
// @version      2.2
// @description  Auto-fill surveys with logic + web search + sliders
// @author       You
// @match        https://eurekasurveys.com/*
// @icon         https://www.google.com/s2/favicons?domain=eurekasurveys.com
// @grant        GM_xmlhttpRequest
// @grant        GM_notification
// @run-at       document-end
// ==/UserScript==

(function() {
    'use strict';

    // ===== CONFIG =====
    const MC_DELAY_MIN = 1000;
    const MC_DELAY_MAX = 2000;
    const TEXT_DELAY_MIN = 2000;
    const TEXT_DELAY_MAX = 3000;
    const SEARCH_TIMEOUT = 5000;
    const RANDOM_FALLBACK = true;

    // ===== STATE =====
    let isRunning = false;
    let stopRequested = false;
    let currentQuestionCount = 0;

    // ===== HELPERS =====
    function clean(text) {
        return text ? text.replace(/\s+/g, ' ').trim() : '';
    }

    function getQuestionText(fieldset) {
        const legend = fieldset.querySelector('legend.question, .question-text, .q-title');
        if (legend) return clean(legend.textContent);
        const p = fieldset.querySelector('p:first-child');
        return p ? clean(p.textContent) : '';
    }

    function getOptionLabels(fieldset) {
        const labels = [];
        fieldset.querySelectorAll('.radio__label, label').forEach(lbl => {
            const txt = clean(lbl.textContent);
            if (txt) labels.push(txt);
        });
        return labels;
    }

    function getInputType(fieldset) {
        if (fieldset.querySelector('input[type="radio"]')) return 'radio';
        if (fieldset.querySelector('input[type="checkbox"]')) return 'checkbox';
        if (fieldset.querySelector('input[type="text"], textarea')) return 'text';
        if (fieldset.querySelector('input[type="range"]')) return 'range';  // <-- NEW
        if (fieldset.querySelector('select')) return 'select';
        return 'unknown';
    }

    // ===== LOCAL LOGIC (attention checks, math, facts) =====
    function localLogic(question, options) {
        const lower = question.toLowerCase();
        const patterns = [
            /select ['"“]([^'"]+)['"”]/i,
            /choose ['"“]([^'"]+)['"”]/i,
            /pick ['"“]([^'"]+)['"”]/i,
        ];
        for (let p of patterns) {
            const m = question.match(p);
            if (m) {
                const target = m[1].toLowerCase().trim();
                for (let opt of options) {
                    if (opt.toLowerCase().includes(target) || target.includes(opt.toLowerCase().slice(0, 10))) {
                        return { type: 'radio', selection: opt };
                    }
                }
            }
        }
        const math = lower.match(/(\d+)\s*([+\-*/])\s*(\d+)/);
        if (math) {
            const a = parseInt(math[1]), b = parseInt(math[3]);
            let res;
            switch (math[2]) {
                case '+': res = a + b; break;
                case '-': res = a - b; break;
                case '*': res = a * b; break;
                case '/': res = Math.round((a / b) * 100) / 100; break;
            }
            if (res !== undefined) {
                const str = res.toString();
                for (let opt of options) {
                    if (opt.includes(str)) return { type: 'radio', selection: opt };
                }
            }
        }
        const facts = {
            'capital of france': 'Paris',
            'capital of germany': 'Berlin',
            '2+2': '4',
        };
        for (let [key, val] of Object.entries(facts)) {
            if (lower.includes(key)) {
                for (let opt of options) {
                    if (opt.toLowerCase().includes(val.toLowerCase())) {
                        return { type: 'radio', selection: opt };
                    }
                }
            }
        }
        return null;
    }

    // ===== WEB SEARCH (DuckDuckGo) =====
    function webSearch(query) {
        return new Promise((resolve, reject) => {
            const url = `https://api.duckduckgo.com/?q=${encodeURIComponent(query)}&format=json&no_html=1&skip_disambig=1`;
            GM_xmlhttpRequest({
                method: 'GET',
                url: url,
                timeout: SEARCH_TIMEOUT,
                onload: function(response) {
                    try {
                        const data = JSON.parse(response.responseText);
                        let answer = data.AbstractText || '';
                        if (!answer && data.RelatedTopics && data.RelatedTopics.length) {
                            answer = data.RelatedTopics[0].Text || '';
                        }
                        resolve(clean(answer));
                    } catch (e) {
                        reject(e);
                    }
                },
                onerror: reject,
                ontimeout: reject
            });
        });
    }

    // ===== GET LOGICAL ANSWER =====
    async function getLogicalAnswer(question, options, inputType) {
        const local = localLogic(question, options);
        if (local) return local;

        let answer = await webSearch(question).catch(() => null);
        if (!answer) {
            if (inputType === 'text') {
                return { type: 'text', selection: 'Generated response for testing.' };
            }
            if (RANDOM_FALLBACK && options.length) {
                const chosen = options[Math.floor(Math.random() * options.length)];
                return { type: 'radio', selection: chosen };
            }
            return null;
        }

        if (inputType === 'text') {
            const sentenceMatch = question.match(/(\d+)\s*sentence/);
            let sentences = answer.split(/[.!?]+/).filter(s => s.trim().length > 0);
            if (sentenceMatch) {
                const count = parseInt(sentenceMatch[1]);
                answer = sentences.slice(0, count).join('. ') + '.';
            } else {
                if (sentences.length > 2) {
                    answer = sentences.slice(0, 2).join('. ') + '.';
                }
            }
            return { type: 'text', selection: answer };
        }

        for (let opt of options) {
            const optClean = opt.toLowerCase();
            const ansClean = answer.toLowerCase();
            if (optClean.includes(ansClean) || ansClean.includes(optClean) ||
                ansClean.split(' ').some(word => optClean.includes(word))) {
                return { type: 'radio', selection: opt };
            }
        }
        if (RANDOM_FALLBACK && options.length) {
            const chosen = options[Math.floor(Math.random() * options.length)];
            return { type: 'radio', selection: chosen };
        }
        return null;
    }

    // ===== SLIDER HELPER =====
    function pickSliderValue(min, max, step) {
        // Pick a value between 20% and 80% of the range (human-like)
        const range = max - min;
        const low = min + range * 0.2;
        const high = min + range * 0.8;
        // Random between low and high, rounded to step
        const raw = low + Math.random() * (high - low);
        const stepped = Math.round(raw / step) * step;
        return Math.min(max, Math.max(min, stepped));
    }

    // ===== FILL QUESTION =====
    async function fillQuestion(fieldset) {
        const qText = getQuestionText(fieldset);
        const options = getOptionLabels(fieldset);
        const type = getInputType(fieldset);
        console.log(`📝 ${qText.slice(0, 70)}...`);

        // For range sliders, we don't need a logical answer from search
        if (type === 'range') {
            const slider = fieldset.querySelector('input[type="range"]');
            if (slider) {
                const min = parseFloat(slider.min) || 0;
                const max = parseFloat(slider.max) || 100;
                const step = parseFloat(slider.step) || 1;
                const value = pickSliderValue(min, max, step);
                slider.value = value;
                // Dispatch events to update any UI
                slider.dispatchEvent(new Event('input', { bubbles: true }));
                slider.dispatchEvent(new Event('change', { bubbles: true }));
                console.log(`   🎚️ Slider set to: ${value}`);
                const delay = MC_DELAY_MIN + Math.random() * (MC_DELAY_MAX - MC_DELAY_MIN);
                await new Promise(r => setTimeout(r, delay));
                return;
            }
            return; // fallback if no slider found
        }

        // For other types, use the existing logic
        const result = await getLogicalAnswer(qText, options, type);
        if (!result) {
            console.warn('⚠️ No answer found, skipping.');
            return;
        }

        if (type === 'radio') {
            const radios = fieldset.querySelectorAll('input[type="radio"]');
            for (let i = 0; i < radios.length; i++) {
                if (options[i] === result.selection) {
                    radios[i].checked = true;
                    radios[i].dispatchEvent(new Event('change', { bubbles: true }));
                    console.log(`   ✅ Selected: "${result.selection}"`);
                    break;
                }
            }
            const delay = MC_DELAY_MIN + Math.random() * (MC_DELAY_MAX - MC_DELAY_MIN);
            await new Promise(r => setTimeout(r, delay));
        } else if (type === 'checkbox') {
            const checks = fieldset.querySelectorAll('input[type="checkbox"]');
            const lowerQ = qText.toLowerCase();
            if (lowerQ.includes('select all') || lowerQ.includes('check all')) {
                checks.forEach(cb => { cb.checked = true; cb.dispatchEvent(new Event('change', { bubbles: true })); });
                console.log('   ☑️ Selected all checkboxes');
            } else {
                for (let i = 0; i < checks.length; i++) {
                    if (options[i] === result.selection) {
                        checks[i].checked = true;
                        checks[i].dispatchEvent(new Event('change', { bubbles: true }));
                        console.log(`   ☑️ Selected: "${result.selection}"`);
                        break;
                    }
                }
            }
            const delay = MC_DELAY_MIN + Math.random() * (MC_DELAY_MAX - MC_DELAY_MIN);
            await new Promise(r => setTimeout(r, delay));
        } else if (type === 'text') {
            const inputs = fieldset.querySelectorAll('input[type="text"], textarea');
            const answerText = result.selection;
            inputs.forEach(inp => {
                inp.value = answerText;
                inp.dispatchEvent(new Event('input', { bubbles: true }));
            });
            console.log(`   ✏️ Text filled: "${answerText.slice(0, 50)}..."`);
            const delay = TEXT_DELAY_MIN + Math.random() * (TEXT_DELAY_MAX - TEXT_DELAY_MIN);
            await new Promise(r => setTimeout(r, delay));
        } else if (type === 'select') {
            const selects = fieldset.querySelectorAll('select');
            selects.forEach(sel => {
                const opts = sel.querySelectorAll('option');
                if (opts.length > 1) {
                    let chosen = null;
                    for (let opt of opts) {
                        if (result.selection && opt.textContent.includes(result.selection)) {
                            chosen = opt;
                            break;
                        }
                    }
                    if (!chosen) chosen = opts[Math.floor(Math.random() * (opts.length - 1)) + 1];
                    sel.value = chosen.value;
                    sel.dispatchEvent(new Event('change', { bubbles: true }));
                    console.log(`   📋 Selected: "${chosen.textContent.trim()}"`);
                }
            });
            const delay = MC_DELAY_MIN + Math.random() * (MC_DELAY_MAX - MC_DELAY_MIN);
            await new Promise(r => setTimeout(r, delay));
        }
    }

    // ===== NAVIGATE =====
    function clickNext() {
        const btn = document.querySelector('button#next, button[type="submit"], .next-btn, .continue-btn');
        if (btn) {
            btn.click();
            return true;
        }
        return false;
    }

    function isSurveyComplete() {
        const fieldset = document.querySelector('fieldset:not([style*="display: none"])');
        const nextBtn = document.querySelector('button#next, button[type="submit"]');
        const thankYou = document.querySelector('.thank-you, .completion, .finish-message');
        if (thankYou && thankYou.textContent.toLowerCase().includes('thank')) return true;
        if (!fieldset && !nextBtn) return true;
        return false;
    }

    function isSurveyPage() {
        return !!document.querySelector('form#question_form, fieldset');
    }

    // ===== UI =====
